{
  "xmtp": {
    "network": "production",
    "dbPath": "~/.everclaw/xmtp",
    "consentPolicy": "handshake",
    "handshake": {
      "timeoutMs": 90000,
      "maxRetries": 3
    },
    "discovery": {
      "defaultRelationship": "unknown",
      "handshakePromotesTo": "stranger"
    },
    "tiers": {
      "logPlaintext": true
    },
    "bridge": {
      "outboxDir": "~/.everclaw/xmtp/outbox",
      "inboxDir": "~/.everclaw/xmtp/inbox",
      "pollIntervalMs": 5000
    },
    "health": {
      "updateIntervalMs": 5000
    },
    "reconnect": {
      "maxBackoffMs": 30000
    }
  }
}
